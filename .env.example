APP_NAME=KALT
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Madrid
APP_URL=http://localhost:8000

# Configuración de Seguridad y Sesión para Sanctum SPA
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173
SESSION_DOMAIN=localhost
SESSION_DRIVER=cookie
COOKIE_HTTP_ONLY=true

# Logs
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Base de Datos (PostgreSQL 16)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=kalt
DB_USERNAME=kalt_user
DB_PASSWORD=kalt_secure_pass

# Caché y Colas (Redis 7)
BROADCAST_CONNECTION=log
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Configuración del Motor de Cálculo (Valores por defecto de KALT)
MIN_PROTEIN_PER_KG=1.8
MAX_PROTEIN_PER_KG=2.2
DEFAULT_CALORIE_SURPLUS=300
DEFAULT_CALORIE_DEFICIT=300

# Mail (Opcional para desarrollo)
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@kalt.app"
MAIL_FROM_NAME="${APP_NAME}"