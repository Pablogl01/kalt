APP_NAME=KALT
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Madrid
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4

# Sanctum SPA Cookie Mode
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173
SESSION_DOMAIN=localhost
SESSION_DRIVER=redis
SESSION_LIFETIME=120
COOKIE_HTTP_ONLY=true

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database (PostgreSQL 16)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=kalt
DB_USERNAME=kalt_user
DB_PASSWORD=kalt_secure_pass

# Cache & Queues (Redis 7)
BROADCAST_CONNECTION=log
CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# KALT Calculation Engine defaults
MIN_PROTEIN_PER_KG=1.8
MAX_PROTEIN_PER_KG=2.2
DEFAULT_CALORIE_SURPLUS=300
DEFAULT_CALORIE_DEFICIT=300

# Mail (log in development)
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@kalt.app"
MAIL_FROM_NAME="${APP_NAME}"
